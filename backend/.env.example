# Backend environment variables
# Required: MongoDB connection string
MONGODB_URI=

# Frontend origins allowed for CORS (comma-separated). Examples:
# FRONTEND_URLS=https://your-app.vercel.app,https://*.vercel.app
FRONTEND_URLS=

# Optional: Explicit single origin (deprecated in favor of FRONTEND_URLS)
# FRONTEND_URL=

# Render provides PORT automatically; no need to set it.
# PORT=
